#!/bin/bash
INSTALL_DIR=/opt/ir-face
VENV=$INSTALL_DIR/venv
NVIDIA_LIBS="$VENV/lib/python$(python3 -c 'import sys; print(f"{sys.version_info.major}.{sys.version_info.minor}")')/site-packages/nvidia"
export LD_LIBRARY_PATH="$NVIDIA_LIBS/cufft/lib:$NVIDIA_LIBS/cublas/lib:$NVIDIA_LIBS/cuda_runtime/lib:/opt/cuda/lib64:${LD_LIBRARY_PATH}"
exec "$VENV/bin/python3" "$INSTALL_DIR/ir_enroll.py" "$@"
